while (1){
    HAL_ADC_Start(&hadc1);
	  HAL_ADC_PollForConversion(&hadc1, HAL_MAX_DELAY);
	  uint32_t adcValue = HAL_ADC_GetValue(&hadc1);

	  inputBuffer[sampleIndex] = (adcValue);
	  sampleIndex++;
    HAL_Delay(1);
	  if(sampleIndex >= BLOCK_SIZE){
		  sampleIndex = 0;

		  
		  for(int i = 0; i < BLOCK_SIZE; i++){
		          HAL_DAC_SetValue(&hdac, DAC_CHANNEL_1, DAC_ALIGN_12B_R, inputBuffer[i]);
		          HAL_DAC_Start(&hdac, DAC_CHANNEL_1);
		          HAL_Delay(1);               
	      }
	  }
